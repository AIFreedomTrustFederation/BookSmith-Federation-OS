{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@booksmith-federation-os/federation-core": ["packages/federation-core/src"],
      "@booksmith-federation-os/storage-core": ["packages/storage-core/src"],
      "@booksmith-federation-os/marketplace-core": ["packages/marketplace-core/src"],
      "@booksmith-federation-os/wallet-core": ["packages/wallet-core/src"],
      "@booksmith-federation-os/booksmith-bridge": ["packages/booksmith-bridge/src"],
      "@booksmith-federation-os/ui": ["packages/ui/src"]
    }
  }
}
